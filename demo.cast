[0.781, "o", "\u001b[?25l\u001b[2d.py --client cli    --results /tmp/shimmer-parity/cli.txt;    touch /tmp/shimmer-parity/.done-cli\u001b[K\u001b[3;102Hcd /w/shimmer && PEBBLE=/home/tony.meyer@canonical.com/pebble-demo DEMO_PACE=1.2 uv run python demo\u001b[4;102H.py --client cli    --results /tmp/shimmer-parity/cli.txt;    touch /tmp/shimmer-parity/.done-cli\u001b[K\u001b[5;102H=== shimmer.PebbleCliClient  (CLI) ===\u001b[K\u001b[6;102H\u001b[K\n• deploy: add layer + replan\u001b[K\u001b[8;102H    \u001b[2m$ pebble add demo /tmp/<tmp>.yaml --combine\u001b(B\u001b[m\u001b[K\u001b[9;102H    \u001b[2m$ pebble replan --no-wait\u001b(B\u001b[m\u001b[K\u001b[10;102H    \u001b[2m$ pebble tasks <id> --format json\u001b(B\u001b[m\u001b[K\u001b[11;102H    \u001b[2m$ pebble version --client\u001b(B\u001b[m\u001b[K\u001b[12;102H• system info: pebble v1.31.0\u001b[K\u001b[13;102H    \u001b[2m$ pebble services --format json\u001b(B\u001b[m\u001b[K\u001b[14;102H• service: demo-server is active (startup enabled)\u001b[K\u001b[15;102H    \u001b[2m$ pebble checks --format json\u001b(B\u001b[m\u001b[K\u001b[16;102H• check: demo-health level=alive\u001b[K\u001b[17;102H    \u001b[2m$ pebble mkdir /tmp/shimmer-demo -p\u001b(B\u001b[m\u001b[K\u001b[18;102H    \u001b[2m$ pebble push /tmp/<tmp> /tmp/shimmer-demo/hello.txt\u001b(B\u001b[m\u001b[K\u001b[19;102H    \u001b[2m$ pebble pull /tmp/shimmer-demo/hello.txt /tmp/<tmp>\u001b(B\u001b[m\u001b[K\u001b[20;102H• file round-trip: 'Hello from Shimmer!'\u001b[K\u001b[21;102H• GET http://localhost:8080 -> HTTP/1.0 200 OK\u001b[K\u001b[22;102H    \u001b[2m$ pebble exec -- echo Hello, World!\u001b(B\u001b[m\u001b[K\u001b[23;102H• exec echo -> Hello, World!\u001b[K\u001b[24;102H\u001b[K\n=== done ===\u001b[K\u001b[26;102H\u001b[K\u001b[?12l\u001b[?25h"]
