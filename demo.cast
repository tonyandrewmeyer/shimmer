[5.053461, "o", "\u001b[?25l\u001b[1;3H ops.pebble.Client   (unix socket) ─────────────────────────────────────────────────────────────\u001b(B\u001b[m\u001b[32m\u001b[5C shimmer.PebbleCliClient   (CLI) ──────────────────────────────────────────────────────────────\u001b(B\u001b[m\u001b[27;3H parity check ────────────────────────────────────────────────────────────────────────────────────┴─────────────────────────────────────────────────────────────────────────────────────────────────\u001b[H──\u001b[96C──\u001b[32m┬──\u001b[95C──\u001b[2;101H│\u001b[3;101H│\u001b[4;101H│\u001b[5;101H│\u001b[6;101H│\u001b[7;101H│\u001b[8;101H│\u001b[9;101H│\u001b[10;101H│\u001b[11;101H│\u001b[12;101H│\u001b[13;101H│\u001b[14;101H│\u001b[15;101H│\u001b[16;101H│\u001b[17;101H│\u001b[18;101H│\u001b[19;101H│\u001b[20;101H│\u001b[21;101H│\u001b[22;101H│\u001b[23;101H│\u001b[24;101H│\u001b[25;101H│\u001b[26;101H│\r\n\u001b[39m──\u001b[196C──\u001b(B\u001b[m\u001b[32m\u001b[1m\u001b[2;1Hubuntu@cascade\u001b(B\u001b[m:\u001b[34m\u001b[1m~/shimmer\u001b(B\u001b[m$ cd /home/ubuntu/shimmer && PEBBLE=/home/ubuntu/pebble-demo DEMO_PACE=0.6 u\r\nv run python demo.py --client socket --results /tmp/shimmer-parity/socket.txt; touch /tmp/shimmer-pa\u001b[4;100H\u001b[1K\rrity/.done-socket\u001b[5;100H\u001b[1K\r=== ops.pebble.Client  (unix socket) ===\u001b[6;100H\u001b[1K\n\u001b[1K\r• deploy: add layer + replan\u001b[8;100H\u001b[1K\r• system info: pebble v1.31.0\r\n• service: demo-server is active (startup enabled)\u001b[50X\u001b[10;100H\u001b[1K\r• check: demo-health level=alive\u001b[11;100H\u001b[1K\r• file round-trip: 'Hello from Shimmer!'\u001b[12;100H\u001b[1K\r• GET http://localhost:8080 -> HTTP/1.0 200 OK\u001b[13;100H\u001b[1K\r• exec echo -> Hello, World!\u001b[14;100H\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\n\u001b[1K\u001b[2;102Hcd /home/ubuntu/shimmer && PEBBLE=/home/ubuntu/pebble-demo DEMO_PACE=0.6 uv run python demo.py --cl\u001b[3;102Hient cli    --results /tmp/shimmer-parity/cli.txt;    touch /tmp/shimmer-parity/.done-cli\u001b[K\u001b[32m\u001b[1m\u001b[4;102Hubuntu@cascade\u001b(B\u001b[m:\u001b[34m\u001b[1m~/shimmer\u001b(B\u001b[m$ cd /home/ubuntu/shimmer && PEBBLE=/home/ubuntu/pebble-demo DEMO_PACE=0.6 \u001b[5;102Huv run python demo.py --client cli    --results /tmp/shimmer-parity/cli.txt;    touch /tmp/shimmer-\u001b[6;102Hparity/.done-cli\u001b[K\u001b[7;102H=== shimmer.PebbleCliClient  (CLI) ===\u001b[K\u001b[8;102H\u001b[K\n• deploy: add layer + replan\u001b[K\u001b[10;102H    \u001b[2m$ pebble add demo /tmp/<tmp>.yaml --combine\u001b(B\u001b[m\u001b[K\u001b[11;102H    \u001b[2m$ pebble replan --no-wait\u001b(B\u001b[m\u001b[K\u001b[12;102H    \u001b[2m$ pebble tasks <id> --format json\u001b(B\u001b[m\u001b[K\u001b[13;102H    \u001b[2m$ pebble version --client\u001b(B\u001b[m\u001b[K\u001b[14;102H• system info: pebble v1.31.0\u001b[K\u001b[15;102H    \u001b[2m$ pebble services --format json\u001b(B\u001b[m\u001b[K\u001b[16;102H• service: demo-server is active (startup enabled)\u001b[K\u001b[17;102H    \u001b[2m$ pebble checks --format json\u001b(B\u001b[m\u001b[K\u001b[18;102H• check: demo-health level=alive\u001b[K\u001b[19;102H    \u001b[2m$ pebble mkdir /tmp/shimmer-demo -p\u001b(B\u001b[m\u001b[K\u001b[20;102H    \u001b[2m$ pebble push /tmp/<tmp> /tmp/shimmer-demo/hello.txt\u001b(B\u001b[m\u001b[K\u001b[21;102H    \u001b[2m$ pebble pull /tmp/shimmer-demo/hello.txt /tmp/<tmp>\u001b(B\u001b[m\u001b[K\u001b[22;102H• file round-trip: 'Hello from Shimmer!'\u001b[K\u001b[23;102H• GET http://localhost:8080 -> HTTP/1.0 200 OK\u001b[K\u001b[24;102H\u001b[K\n\u001b[K\n\u001b[K\u001b[32m\u001b[1m\u001b[28;1Hubuntu@cascade\u001b(B\u001b[m:\u001b[34m\u001b[1m~/shimmer\u001b(B\u001b[m$ bash /tmp/shimmer-demo-controller.sh\u001b[K\r\nwaiting for both clients to finish ...\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n\u001b[K\r\